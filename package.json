{
  "name": "netiploy",
  "version": "1.0.0",
  "module": "src/index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "netiploy": "./build/netiploy"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "oxfmt": "^0.49.0",
    "prettier": "3.8.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "nanoid": "^5.1.11"
  },
  "scripts": {
    "prepare": "husky",
    "build": "bun run build:all",
    "build:linux:x64": "bun build ./src/cli.ts ./src/core/worker.ts --compile --minify --sourcemap --bytecode --target=bun-linux-x64 --outfile build/netiploy-linux-x64",
    "build:linux:arm": "bun build ./src/cli.ts ./src/core/worker.ts --compile --minify --sourcemap --bytecode --target=bun-linux-arm64 --outfile build/netiploy-linux-arm64",
    "build:mac:x64": "bun build ./src/cli.ts ./src/core/worker.ts --compile --minify --sourcemap --bytecode --target=bun-darwin-x64 --outfile build/netiploy-macos-x64",
    "build:mac:arm": "bun build ./src/cli.ts ./src/core/worker.ts --compile --minify --sourcemap --bytecode --target=bun-darwin-arm64 --outfile build/netiploy-macos-arm64",
    "build:win:x64": "bun build ./src/cli.ts ./src/core/worker.ts --compile --minify --sourcemap --bytecode --target=bun-windows-x64 --outfile build/netiploy-win-x64.exe",
    "build:win:arm": "bun build ./src/cli.ts ./src/core/worker.ts --compile --minify --sourcemap --bytecode --target=bun-windows-arm64 --outfile build/netiploy-win-arm64.exe",
    "build:all": "bun run build:linux:x64 && bun run build:linux:arm && bun run build:mac:x64 && bun run build:mac:arm && bun run build:win:x64 && bun run build:win:arm",
    "test": "bun test tests/e2e.test.ts",
    "test:e2e": "docker compose up -d && bun test tests/e2e.test.ts",
    "dev:fmt": "bun x prettier -w ."
  },
  "lint-staged": {
    "**/*": "prettier --write --ignore-unknown"
  }
}
